#!/bin/bash
# PwnTheBox Quick Launcher

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Show quick banner
echo -e "${CYAN}"
echo "╔═══════════════════════════════════════════════════════════════════════════════╗"
echo "║                                                                               ║"
echo "║                    PWNTHEBOX FRAMEWORK                                      ║"
echo "║              Professional Penetration Testing Suite                           ║"
echo "║                                                                               ║"
echo "╚═══════════════════════════════════════════════════════════════════════════════╝"
echo -e "${NC}"
echo ""

# Check if framework directory exists
if [[ ! -d "$SCRIPT_DIR" ]]; then
    echo -e "${RED}[!] Error: Framework directory not found: $SCRIPT_DIR${NC}"
    exit 1
fi

# Change to framework directory
cd "$SCRIPT_DIR"

# Check if pwnthebox.sh exists
if [[ ! -f "./pwnthebox.sh" ]]; then
    echo -e "${RED}[!] Error: pwnthebox.sh not found in $SCRIPT_DIR${NC}"
    echo -e "${YELLOW}[!] Make sure the framework is properly installed.${NC}"
    exit 1
fi

# Make pwnthebox.sh executable
chmod +x ./pwnthebox.sh

# Run pwnthebox.sh with any passed arguments
./pwnthebox.sh "$@"

# Exit with conductor's exit code
exit $?
